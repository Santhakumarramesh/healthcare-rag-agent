data/faiss_index/*.faiss
data/faiss_index/*.pkl
vectorstore/faiss_index/
vectorstore/faiss_index_test/

# Logs
logs/*.log

# Documentation (not needed in image)
docs/

# Node (if any frontend tooling is ever added)
node_modules/
