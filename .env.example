# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Vector Store
FAISS_INDEX_PATH=./vectorstore/faiss_index
VECTOR_STORE_TYPE=faiss   # "faiss" or "pinecone"

# Pinecone (optional — upgrade path)
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX_NAME=healthcare-rag
PINECONE_ENVIRONMENT=us-east-1

# App Settings
APP_ENV=development
LOG_LEVEL=INFO
MAX_RETRIEVED_DOCS=5
RERANK_TOP_K=3
CONFIDENCE_THRESHOLD=0.6

# Local LLM — Privacy Mode (AirLLM + Apple MLX)
# Set LOCAL_MODE=true to run entirely on-device (no API key needed, no data leaves Mac)
LOCAL_MODE=false
LOCAL_MODEL_ID=mlx-community/Meta-Llama-3-8B-Instruct-4bit

# API
API_HOST=0.0.0.0
API_PORT=8000

# RAGAS Evaluation
EVAL_SAMPLE_SIZE=20
